<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Base ──────────────────────────────────────────────── -->
    <Color x:Key="ColorBase">#1A1815</Color>
    <Color x:Key="ColorSurface">#211F1C</Color>
    <Color x:Key="ColorSurfaceElevated">#2A2723</Color>
    <Color x:Key="ColorBorder">#38352F</Color>
    <Color x:Key="ColorBorderSubtle">#2D2B26</Color>

    <!-- ── Text ──────────────────────────────────────────────── -->
    <Color x:Key="ColorTextPrimary">#EAE6DF</Color>
    <Color x:Key="ColorTextSecondary">#9A9489</Color>
    <Color x:Key="ColorTextMuted">#635F59</Color>

    <!-- ── Accent (âmbar) ────────────────────────────────────── -->
    <Color x:Key="ColorAccent">#D4884A</Color>
    <Color x:Key="ColorAccentDim">#A8682E</Color>
    <Color x:Key="ColorAccentSubtle">#2E2219</Color>

    <!-- ── Semânticas ─────────────────────────────────────────── -->
    <Color x:Key="ColorSuccess">#4E9E6A</Color>
    <Color x:Key="ColorSuccessSubtle">#162419</Color>
    <Color x:Key="ColorError">#C0504A</Color>
    <Color x:Key="ColorErrorSubtle">#2A1514</Color>
    <Color x:Key="ColorWarning">#C49A3C</Color>

    <!-- ── Especiais ─────────────────────────────────────────── -->
    <Color x:Key="ColorVideoBackground">#0F0E0D</Color>

    <!-- SolidColorBrush para uso em XAML ──────────────────────── -->
    <SolidColorBrush x:Key="BrushBase"            Color="{StaticResource ColorBase}"/>
    <SolidColorBrush x:Key="BrushSurface"         Color="{StaticResource ColorSurface}"/>
    <SolidColorBrush x:Key="BrushSurfaceElevated" Color="{StaticResource ColorSurfaceElevated}"/>
    <SolidColorBrush x:Key="BrushBorder"          Color="{StaticResource ColorBorder}"/>
    <SolidColorBrush x:Key="BrushBorderSubtle"    Color="{StaticResource ColorBorderSubtle}"/>

    <SolidColorBrush x:Key="BrushTextPrimary"     Color="{StaticResource ColorTextPrimary}"/>
    <SolidColorBrush x:Key="BrushTextSecondary"   Color="{StaticResource ColorTextSecondary}"/>
    <SolidColorBrush x:Key="BrushTextMuted"       Color="{StaticResource ColorTextMuted}"/>

    <SolidColorBrush x:Key="BrushAccent"          Color="{StaticResource ColorAccent}"/>
    <SolidColorBrush x:Key="BrushAccentDim"       Color="{StaticResource ColorAccentDim}"/>
    <SolidColorBrush x:Key="BrushAccentSubtle"    Color="{StaticResource ColorAccentSubtle}"/>

    <SolidColorBrush x:Key="BrushSuccess"         Color="{StaticResource ColorSuccess}"/>
    <SolidColorBrush x:Key="BrushSuccessSubtle"   Color="{StaticResource ColorSuccessSubtle}"/>
    <SolidColorBrush x:Key="BrushError"           Color="{StaticResource ColorError}"/>
    <SolidColorBrush x:Key="BrushErrorSubtle"     Color="{StaticResource ColorErrorSubtle}"/>
    <SolidColorBrush x:Key="BrushWarning"         Color="{StaticResource ColorWarning}"/>

    <SolidColorBrush x:Key="BrushVideoBackground" Color="{StaticResource ColorVideoBackground}"/>

</ResourceDictionary>
